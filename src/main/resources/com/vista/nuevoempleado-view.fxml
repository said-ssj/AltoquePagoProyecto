<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="fondo-principal" stylesheets="@../stylesCSS/Style-NuevoEmpleado.css" xmlns="http://javafx.com/javafx/17.0.14" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controlador.ControladorNuevoEmpleado">
    <VBox spacing="20.0" styleClass="fondo-principal">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <Label styleClass="titulo-principal" text="Registro de Nuevo Empleado" />

        <Button fx:id="btnMostrarInfoPersonal" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-seccion-incompleta" text="+ Información Personal (Requerido)" />

        <VBox fx:id="panelInfoPersonal" managed="false" spacing="15.0" styleClass="tarjeta-cliente" visible="false">
            <HBox alignment="CENTER_LEFT">
                <Label maxWidth="Infinity" styleClass="subtitulo-tarjeta" text="Información Personal" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnCerrarInfoPersonal" mnemonicParsing="false" styleClass="btn-cerrar" text="✕" />
            </HBox>

            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                </columnConstraints>

                <Label styleClass="etiqueta-form" text="Nombre Completo (*)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombre" promptText="Ej. Carlos Admin" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Fecha de Nacimiento (*)" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <DatePicker fx:id="dpFechaNacimiento" maxWidth="Infinity" promptText="dd/mm/aaaa" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Tipo de Documento (*)" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="cbTipoDocumento" maxWidth="Infinity" promptText="DNI" styleClass="combo-box-form" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                <Label styleClass="etiqueta-form" text="Número de Documento (*)" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="txtNumeroDocumento" promptText="8 a 12 dígitos" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label styleClass="etiqueta-form" text="Nacionalidad (*)" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtNacionalidad" text="Peruano" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            </GridPane>
            <Button fx:id="btnGuardarInfoPersonal" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-secundario" text="Confirmar Sección" />
        </VBox>

        <Button fx:id="btnMostrarContacto" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-seccion-incompleta" text="+ Datos de Contacto y Acceso (Requerido)" />

        <VBox fx:id="panelContacto" managed="false" spacing="15.0" styleClass="tarjeta-cliente" visible="false">
            <HBox alignment="CENTER_LEFT">
                <Label maxWidth="Infinity" styleClass="subtitulo-tarjeta" text="Datos de Contacto" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnCerrarContacto" mnemonicParsing="false" styleClass="btn-cerrar" text="✕" />
            </HBox>

            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                </columnConstraints>

                <Label styleClass="etiqueta-form" text="Correo (Usuario de Acceso) (*)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtEmail" promptText="empleado@minimarket.com" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Contraseña del Sistema (*)" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <PasswordField fx:id="txtContraseña" promptText="Mínimo 8 caracteres" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Rol / Permisos (*)" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="cbRol" maxWidth="Infinity" promptText="Seleccionar Rol" styleClass="combo-box-form" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                <Label styleClass="etiqueta-form" text="Teléfono Personal (*)" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="txtTelefono" promptText="999 888 777" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label styleClass="etiqueta-form" text="Dirección (Opcional)" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtDireccion" promptText="Distrito, calle, número" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                <Label styleClass="etiqueta-form" text="Teléfono de Emergencia (Opcional)" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <TextField fx:id="txtTelefonoEmergencia" promptText="Familiar o contacto" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </GridPane>
            <Button fx:id="btnGuardarContacto" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-secundario" text="Confirmar Sección" />
        </VBox>

        <Button fx:id="btnMostrarLaboral" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-seccion-incompleta" text="+ Información Laboral (Requerido)" />

        <VBox fx:id="panelLaboral" managed="false" spacing="15.0" styleClass="tarjeta-cliente" visible="false">
            <HBox alignment="CENTER_LEFT">
                <Label maxWidth="Infinity" styleClass="subtitulo-tarjeta" text="Información Laboral" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnCerrarLaboral" mnemonicParsing="false" styleClass="btn-cerrar" text="✕" />
            </HBox>
            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                </columnConstraints>
                <Label styleClass="etiqueta-form" text="Área (*)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="cbArea" maxWidth="Infinity" promptText="Ventas, Almacén, etc." styleClass="combo-box-form" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Tipo de Contrato (*)" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <ComboBox fx:id="cbTipoContrato" maxWidth="Infinity" promptText="Tiempo completo..." styleClass="combo-box-form" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Fecha de Inicio (*)" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <DatePicker fx:id="dpFechaInicio" maxWidth="Infinity" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            </GridPane>
            <Button fx:id="btnGuardarLaboral" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-secundario" text="Confirmar Sección" />
        </VBox>

        <Button fx:id="btnMostrarCompensacion" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-seccion-incompleta" text="+ Compensación y Beneficios (Requerido)" />

        <VBox fx:id="panelCompensacion" managed="false" spacing="15.0" styleClass="tarjeta-cliente" visible="false">
            <HBox alignment="CENTER_LEFT">
                <Label maxWidth="Infinity" styleClass="subtitulo-tarjeta" text="Compensación" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnCerrarCompensacion" mnemonicParsing="false" styleClass="btn-cerrar" text="✕" />
            </HBox>
            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                </columnConstraints>
                <Label styleClass="etiqueta-form" text="Salario Base S/ (*)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtSalario" promptText="0.00" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Método de Pago (*)" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <ComboBox fx:id="cbMetodoPago" maxWidth="Infinity" promptText="Efectivo, Transferencia" styleClass="combo-box-form" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label styleClass="etiqueta-form" text="Datos Bancarios (Banco / Cuenta / CCI) (*)" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2" />
                <TextField fx:id="txtDatosBancarios" promptText="Ej. BCP - Cuenta Ahorros - 191-0000000" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" />
            </GridPane>
            <Button fx:id="btnGuardarCompensacion" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-secundario" text="Confirmar Sección" />
        </VBox>

        <Button fx:id="btnMostrarDocumentacion" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-seccion-incompleta" text="+ Documentación (Opcional)" />

        <VBox fx:id="panelDocumentacion" managed="false" spacing="15.0" styleClass="tarjeta-cliente" visible="false">
            <HBox alignment="CENTER_LEFT">
                <Label maxWidth="Infinity" styleClass="subtitulo-tarjeta" text="Documentos Adjuntos" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnCerrarDocumentacion" mnemonicParsing="false" styleClass="btn-cerrar" text="✕" />
            </HBox>
            <VBox spacing="10.0">
                <Label styleClass="etiqueta-form" text="Certificados de Antecedentes (Penales/Policiales)" />
                <ComboBox fx:id="cbAntecedentes" maxWidth="Infinity" promptText="Estado de entrega" styleClass="combo-box-form" />
            </VBox>
            <Button fx:id="btnGuardarDocumentacion" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-secundario" text="Guardar Cambios" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 20 0 0 0;">
            <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#abrirEmpleados" styleClass="btn-secundario" text="Cancelar" />

            <Button fx:id="btnGuardarGeneral" disable="true" mnemonicParsing="false" onAction="#guardarEmpleadoGeneral" prefWidth="250.0" style="-fx-font-size: 16px;" styleClass="btn-primario" text="Guardar Empleado" />
        </HBox>

    </VBox>
</ScrollPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="fondo-pantalla-metodo" stylesheets="@../stylesCSS/Style-KioskoMetodo.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controlador.ControladorAutoservicioMetodo">

    <VBox alignment="CENTER" maxWidth="800.0" styleClass="tarjeta-formulario-kiosko">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <VBox fx:id="cabeceraTexto" alignment="CENTER" styleClass="cabecera-seccion">
            <Label styleClass="titulo-principal-metodo" text="Realizar Pago" />
            <Label prefHeight="25.0" prefWidth="413.0" styleClass="subtitulo-metodo" text="Siga las instrucciones según su método de pago preferido.">
            <VBox.margin>
               <Insets bottom="15.0" />
            </VBox.margin></Label>
        </VBox>

        <HBox fx:id="contenedorMetodos" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="339.0" prefWidth="720.0" spacing="30.0">

            <VBox fx:id="btnOpcionQr" alignment="CENTER" onMouseClicked="#seleccionarQr" styleClass="caja-metodo-pago" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30.0" left="25.0" right="25.0" top="30.0" />
                </padding>

                <Label styleClass="titulo-metodo-pago" text="Yape / Plin" />

                <StackPane styleClass="contenedor-visual-pago">
                    <FontIcon fx:id="iconoQrBoton" iconColor="#0F172A" iconLiteral="fas-qrcode" iconSize="90" />

                    <ImageView fx:id="imgCodigoQR" pickOnBounds="true" preserveRatio="true" styleClass="qr-real-kiosko" />
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
                </StackPane>

                <Label fx:id="lblInstruccionQr" styleClass="texto-instruccion-metodo" text="Toque el ícono para generar el código QR de pago." textAlignment="CENTER" wrapText="true" />
            <HBox.margin>
               <Insets />
            </HBox.margin>
            </VBox>

            <VBox fx:id="btnOpcionTarjeta" alignment="CENTER" onMouseClicked="#seleccionarTarjeta" styleClass="caja-metodo-pago" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30.0" left="25.0" right="25.0" top="30.0" />
                </padding>

                <Label styleClass="titulo-metodo-pago" text="Tarjeta Débito / Crédito" />

                <StackPane styleClass="contenedor-visual-pago">
                    <FontIcon iconColor="#0F172A" iconLiteral="fas-credit-card" iconSize="80" styleClass="icono-interactivo" />
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
                </StackPane>

                <Label fx:id="lblInstruccionTarjeta" styleClass="texto-instruccion-metodo" text="Seleccione esta opción si usará el terminal electrónico." textAlignment="CENTER" wrapText="true" />
            </VBox>

        </HBox>
    </VBox>
</VBox>

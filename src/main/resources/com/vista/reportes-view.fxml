<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true"
            styleClass="fondo-principal"
            stylesheets="@../stylesCSS/Style-Reportes.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controlador.ControladorReportes">

    <content>
        <VBox maxWidth="Infinity" spacing="20.0" styleClass="fondo-principal">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>

                <Label text="Reportes" styleClass="titulo-principal" />

                <!-- ====== TARJETAS DE GENERACIÓN ====== -->
                <HBox spacing="25.0">
                    <children>

                        <!-- VENTAS -->
                        <VBox prefHeight="260.0" prefWidth="290.0" spacing="15.0" styleClass="tarjeta-dashboard">
                            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                            <children>
                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="55.0" prefWidth="55.0" styleClass="icono-caja-ventas">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fas-file-alt" iconSize="26" />
                                </StackPane>
                                <Label text="Generar Reporte de Ventas" wrapText="true" styleClass="titulo-tarjeta" />
                                <Label prefHeight="40.0" text="Reporte mensual de ventas con desglose por producto y cliente" wrapText="true" styleClass="texto-secundario" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button fx:id="btnGenerarVentas" maxWidth="Infinity" mnemonicParsing="false" text="Generar" styleClass="boton-generar-azul" />
                            </children>
                        </VBox>

                        <!-- INVENTARIO -->
                        <VBox prefHeight="260.0" prefWidth="290.0" spacing="15.0" styleClass="tarjeta-dashboard">
                            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                            <children>
                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="55.0" prefWidth="55.0" styleClass="icono-caja-inventario">
                                    <FontIcon iconColor="#16a34a" iconLiteral="fas-file-alt" iconSize="26" />
                                </StackPane>
                                <Label text="Generar Reporte de Inventario" wrapText="true" styleClass="titulo-tarjeta" />
                                <Label prefHeight="40.0" text="Estado semanal del inventario y productos con bajo stock" wrapText="true" styleClass="texto-secundario" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button fx:id="btnGenerarInventario" maxWidth="Infinity" mnemonicParsing="false" text="Generar" styleClass="boton-generar-verde" />
                            </children>
                        </VBox>

                        <!-- EMPLEADOS -->
                        <VBox prefHeight="260.0" prefWidth="290.0" spacing="15.0" styleClass="tarjeta-dashboard">
                            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                            <children>
                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="55.0" prefWidth="55.0" styleClass="icono-caja-personalizado">
                                    <FontIcon iconColor="#9333ea" iconLiteral="fas-file-alt" iconSize="26" />
                                </StackPane>
                                <Label text="Generar Reporte de Empleados" wrapText="true" styleClass="titulo-tarjeta" />
                                <Label prefHeight="40.0" text="Listado semanal de empleados con área, contrato y salario" wrapText="true" styleClass="texto-secundario" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button fx:id="btnGenerarPersonalizado" maxWidth="Infinity" mnemonicParsing="false" text="Generar" styleClass="boton-generar-morado" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- ====== HISTORIAL (reportes anteriores al periodo reciente) ====== -->
                <VBox styleClass="tarjeta-dashboard">
                    <padding><Insets bottom="20.0" left="30.0" right="30.0" top="25.0" /></padding>
                    <children>
                        <!-- Se muestra/oculta dinámicamente si hay historial -->
                        <Label fx:id="lblTituloHistorial" text="Historial de Reportes"
                               styleClass="subtitulo-tarjeta" visible="false" managed="false">
                            <VBox.margin><Insets bottom="12.0" /></VBox.margin>
                        </Label>
                        <Separator prefWidth="200.0" styleClass="separador-ligero" />

                        <!-- Filas generadas dinámicamente por el controlador -->
                        <VBox fx:id="contenedorHistorial" spacing="0" />
                    </children>
                </VBox>

                <!-- ====== REPORTES RECIENTES ====== -->
                <VBox styleClass="tarjeta-dashboard" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="30.0" right="30.0" top="25.0" /></padding>
                    <children>
                        <Label text="Reportes Recientes" styleClass="subtitulo-tarjeta">
                            <VBox.margin><Insets bottom="12.0" /></VBox.margin>
                        </Label>
                        <Separator prefWidth="200.0" styleClass="separador-ligero" />

                        <!-- Filas generadas dinámicamente por el controlador -->
                        <VBox fx:id="contenedorRecientes" spacing="0" />

                        <!-- Mensaje si no hay recientes -->
                        <Label text="No hay reportes recientes. Genera uno con los botones de arriba."
                               styleClass="texto-secundario"
                               wrapText="true">
                            <VBox.margin><Insets top="16.0" /></VBox.margin>
                        </Label>
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
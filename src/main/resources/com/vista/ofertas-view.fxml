<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@../stylesCSS/Style-Tables.css, @../stylesCSS/Style-Ofertas.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controlador.ControladorOfertas">
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="titulo-vista" text="Gestión de Ofertas y Promociones" />
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <TextField fx:id="txtBuscar" prefHeight="35.0" prefWidth="300.0" promptText="Buscar oferta o producto..." styleClass="control-entrada" />
                        <Button mnemonicParsing="false" onAction="#buscarOferta" prefHeight="35.0" prefWidth="100.0" styleClass="btn-secundario" text="Buscar" />
                    </children>
                </HBox>
                <TableView fx:id="tablaOfertas" styleClass="tabla" prefHeight="550.0" prefWidth="650.0" VBox.vgrow="ALWAYS">                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colProducto" prefWidth="150.0" text="Producto" />
                        <TableColumn fx:id="colDescripcion" prefWidth="200.0" text="Descripción" />
                        <TableColumn fx:id="colDescuento" prefWidth="90.0" text="Dscto (S/)" />
                        <TableColumn fx:id="colColor" prefWidth="100.0" text="Color" />
                        <TableColumn fx:id="colInicio" prefWidth="100.0" text="Inicio" />
                        <TableColumn fx:id="colFin" prefWidth="100.0" text="Fin" />
                        <TableColumn fx:id="colEstado" prefWidth="80.0" text="Estado" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="10.0" top="20.0" />
            </padding>
        </VBox>
    </center>
    <right>
        <VBox prefHeight="700.0" prefWidth="320.0" spacing="15.0" styleClass="panel-formulario" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="subtitulo-vista" text="Detalle de Oferta" />
                <Separator prefWidth="200.0" />

                <Label text="Producto:" />
                <TextField fx:id="txtBuscarProductoOfertas" prefHeight="35.0" prefWidth="280.0" promptText="Seleccione un producto" />

                <Label text="Descripción de la Promoción:" />
                <TextField fx:id="txtDescripcion" prefHeight="35.0" prefWidth="280.0" promptText="Ej: 2x1 en Galletas..." styleClass="control-entrada"/>

                <Label text="Descuento (S/):" />
                <TextField fx:id="txtDescuento" prefHeight="35.0" prefWidth="280.0" promptText="0.00" styleClass="control-entrada"/>

                <HBox spacing="10.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Fecha Inicio:" />
                                <DatePicker fx:id="dpInicio" prefHeight="35.0" prefWidth="135.0" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Fecha Fin:" />
                                <DatePicker fx:id="dpFin" prefHeight="35.0" prefWidth="135.0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <CheckBox fx:id="chkEstado" mnemonicParsing="false" selected="true" text="Oferta Activa" />

                <VBox spacing="5.0">
                    <Label text="Color del ticket en el kiosko (opcional):" />
                    <ColorPicker fx:id="colorPickerOferta" prefHeight="35.0" prefWidth="280.0" />
                </VBox>

                <VBox alignment="BOTTOM_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button mnemonicParsing="false" onAction="#guardarOferta" prefHeight="45.0" prefWidth="280.0" styleClass="btn-guardar-oferta" text="Guardar Oferta" />
                        <Button mnemonicParsing="false" onAction="#limpiarFormulario" prefHeight="40.0" prefWidth="280.0" styleClass="btn-limpiar" text="Limpiar / Nuevo" />
                    </children>
                    <padding>
                        <Insets bottom="20.0" />
                    </padding>
                </VBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </right>
</BorderPane>
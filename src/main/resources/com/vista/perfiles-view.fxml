<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-principal" stylesheets="@../stylesCSS/Style-Perfiles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controlador.ControladorPerfiles">
    <content>
        <VBox prefHeight="800.0" prefWidth="1013.0" spacing="25.0" styleClass="fondo-principal">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <VBox spacing="5.0">
                <Label styleClass="titulo-principal" text="Perfiles de Acceso" />
                <Label styleClass="texto-secundario" text="Gestión de roles y permisos del sistema" />
            </VBox>

            <HBox spacing="25.0" VBox.vgrow="ALWAYS">

                <VBox prefWidth="300.0" spacing="15.0" styleClass="tarjeta-dashboard">
                    <Label styleClass="subtitulo-seccion" text="Roles del Sistema" />
                    <Separator styleClass="separador-ligero" />

                    <VBox spacing="10.0">
                        <fx:define>
                            <ToggleGroup fx:id="grupoRoles" />
                        </fx:define>

                        <ToggleButton fx:id="btnRolAdmin" maxWidth="Infinity" mnemonicParsing="false" onAction="#seleccionarAdmin" selected="true" styleClass="btn-rol" text="Administrador" toggleGroup="$grupoRoles" />
                        <ToggleButton fx:id="btnRolVendedor" maxWidth="Infinity" mnemonicParsing="false" onAction="#seleccionarVendedor" styleClass="btn-rol" text="Vendedor" toggleGroup="$grupoRoles" />
                        <ToggleButton fx:id="btnRolAlmacen" maxWidth="Infinity" mnemonicParsing="false" onAction="#seleccionarAlmacen" styleClass="btn-rol" text="Almacén" toggleGroup="$grupoRoles" />
                    </VBox>
                </VBox>

                <VBox spacing="20.0" styleClass="tarjeta-dashboard" HBox.hgrow="ALWAYS">

                    <Label fx:id="lblTituloPermisos" styleClass="subtitulo-seccion" text="Permisos - Administrador" />
                    <Separator styleClass="separador-ligero" />

                    <VBox spacing="15.0">
                        <HBox alignment="CENTER_LEFT" styleClass="fila-permiso">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="etiqueta-form" text="Módulo de Ventas" />
                                <Label styleClass="texto-secundario" text="Acceso al punto de venta y registro de transacciones" />
                            </VBox>
                            <CheckBox fx:id="chkVentas" mnemonicParsing="false" styleClass="checkbox-switch" />
                        </HBox>
                        <Separator styleClass="separador-ligero" />

                        <HBox alignment="CENTER_LEFT" styleClass="fila-permiso">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="etiqueta-form" text="Módulo de Productos" />
                                <Label styleClass="texto-secundario" text="Creación, edición y control de inventario" />
                            </VBox>
                            <CheckBox fx:id="chkProductos" mnemonicParsing="false" styleClass="checkbox-switch" />
                        </HBox>
                        <Separator styleClass="separador-ligero" />

                        <HBox alignment="CENTER_LEFT" styleClass="fila-permiso">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="etiqueta-form" text="Módulo de Empleados" />
                                <Label styleClass="texto-secundario" text="Gestión de personal y contratos" />
                            </VBox>
                            <CheckBox fx:id="chkEmpleados" mnemonicParsing="false" styleClass="checkbox-switch" />
                        </HBox>
                        <Separator styleClass="separador-ligero" />

                        <HBox alignment="CENTER_LEFT" styleClass="fila-permiso">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="etiqueta-form" text="Módulo de Reportes" />
                                <Label styleClass="texto-secundario" text="Visualización de métricas y exportación de datos" />
                            </VBox>
                            <CheckBox fx:id="chkReportes" mnemonicParsing="false" styleClass="checkbox-switch" />
                        </HBox>
                        <Separator styleClass="separador-ligero" />

                        <HBox alignment="CENTER_LEFT" styleClass="fila-permiso">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="etiqueta-form" text="Configuración del Sistema" />
                                <Label styleClass="texto-secundario" text="Acceso a roles, permisos y ajustes generales" />
                            </VBox>
                            <CheckBox fx:id="chkConfiguracion" mnemonicParsing="false" styleClass="checkbox-switch" />
                        </HBox>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="btnGuardarPermisos" mnemonicParsing="false" styleClass="btn-principal" text="Guardar Cambios" />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-principal" stylesheets="@../stylesCSS/Style-NuevoEmpleado.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controlador.ControladorNuevoEmpleado">
    <content>
        <VBox prefHeight="800.0" prefWidth="1013.0" spacing="25.0" styleClass="fondo-principal">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#abrirEmpleados" styleClass="btn-volver" text="" >
                    <graphic>

                        <FontIcon iconColor="#334155" iconLiteral="fas-arrow-left" iconSize="16" />

                    </graphic>
                </Button>
                <Label styleClass="titulo-vista" text="Nuevo Empleado" />
            </HBox>

            <VBox styleClass="tarjeta-cliente" spacing="20.0">

                <Label maxWidth="Infinity" styleClass="subtitulo-seccion" text="Detalles del Empleado" />

                <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                    </columnConstraints>

                    <Label styleClass="etiqueta-form" text="Nombre(s)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtNombre" promptText="Ej: Carlos Alberto" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                    <Label styleClass="etiqueta-form" text="Apellido(s)" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <TextField fx:id="txtApellido" promptText="Ej: Gómez Pérez" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label styleClass="etiqueta-form" text="ID Empleado" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="txtIdEmpleado" promptText="Ej: EMP-001" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                    <Label styleClass="etiqueta-form" text="Email Corporativo" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <TextField fx:id="txtEmail" promptText="empleado@empresa.com" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label styleClass="etiqueta-form" text="Teléfono" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <TextField fx:id="txtTelefono" promptText="(555) 123-4567" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                    <Label styleClass="etiqueta-form" text="Fecha de Nacimiento" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <TextField fx:id="txtFechaNacimiento" promptText="dd/mm/aaaa" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <Label styleClass="etiqueta-form" text="Departamento" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <ComboBox fx:id="cbDepartamento" maxWidth="Infinity" promptText="Seleccionar departamento" styleClass="combo-box-form" GridPane.columnIndex="0" GridPane.rowIndex="7" />

                    <Label styleClass="etiqueta-form" text="Puesto" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                    <TextField fx:id="txtPuesto" promptText="Ej: Vendedor de Mostrador" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                    <Label styleClass="etiqueta-form" text="Fecha de Ingreso" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                    <TextField fx:id="txtFechaIngreso" promptText="dd/mm/aaaa" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="9" />

                    <Label styleClass="etiqueta-form" text="Salario" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                    <TextField fx:id="txtSalario" promptText="S/ 0.00" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="9" />

                    <Label styleClass="etiqueta-form" text="Tipo de Contrato" GridPane.columnIndex="0" GridPane.rowIndex="10" />
                    <ComboBox fx:id="cbTipoContrato" maxWidth="Infinity" promptText="Seleccionar tipo" styleClass="combo-box-form" GridPane.columnIndex="0" GridPane.rowIndex="11" />

                    <Label styleClass="etiqueta-form" text="Estado" GridPane.columnIndex="1" GridPane.rowIndex="10" />
                    <ComboBox fx:id="cbEstado" maxWidth="Infinity" promptText="Seleccionar estado" styleClass="combo-box-form" GridPane.columnIndex="1" GridPane.rowIndex="11" />

                    <Label styleClass="etiqueta-form" text="Dirección" GridPane.columnIndex="0" GridPane.rowIndex="12" GridPane.columnSpan="2" />
                    <TextField fx:id="txtDireccion" promptText="Calle, Avenida, Número..." styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="13" GridPane.columnSpan="2" />

                    <Label styleClass="etiqueta-form" text="Ciudad" GridPane.columnIndex="0" GridPane.rowIndex="14" />
                    <TextField fx:id="txtCiudad" promptText="Ej: Ica" styleClass="text-field-form" GridPane.columnIndex="0" GridPane.rowIndex="15" />

                    <Label styleClass="etiqueta-form" text="Código Postal" GridPane.columnIndex="1" GridPane.rowIndex="14" />
                    <TextField fx:id="txtCodigoPostal" promptText="Ej: 11000" styleClass="text-field-form" GridPane.columnIndex="1" GridPane.rowIndex="15" />

                    <Label styleClass="etiqueta-form" text="Notas Adicionales" GridPane.columnIndex="0" GridPane.rowIndex="16" GridPane.columnSpan="2" />
                    <TextArea fx:id="txtNotas" prefRowCount="3" promptText="Información extra relevante..." styleClass="text-area-form" GridPane.columnIndex="0" GridPane.rowIndex="17" GridPane.columnSpan="2" />
                </GridPane>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#abrirEmpleados" styleClass="btn-cancelar" text="Cancelar" />
                <Button fx:id="btnGuardarEmpleado" mnemonicParsing="false" styleClass="btn-principal" text="Guardar Empleado" />
            </HBox>

        </VBox>
    </content>
</ScrollPane>
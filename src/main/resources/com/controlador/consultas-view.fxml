<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="800.0" prefWidth="1013.0" spacing="20.0"
      style="-fx-background-color: #f1f5f9;"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controlador.ControladorConsultas">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>

        <Label text="Consultas" textFill="#1e293b">
            <font>
                <Font name="Segoe UI Bold" size="28.0" />
            </font>
        </Label>

        <GridPane hgap="20.0" vgap="20.0" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS" />
                <RowConstraints vgrow="ALWAYS" />
            </rowConstraints>

            <VBox spacing="14.0" styleClass="tarjeta-dashboard"
                  stylesheets="@../stylesCSS/Style-Dashboard.css"
                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                <children>
                    <Label text="Consulta de Ventas" textFill="#1e293b">
                        <font><Font name="Segoe UI Semibold" size="18.0" /></font>
                        <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                    </Label>

                    <Label text="Fecha Inicio" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <DatePicker fx:id="dateInicioVentas" promptText="dd/mm/aaaa" maxWidth="Infinity"
                                style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;">
                    </DatePicker>

                    <Label text="Fecha Fin" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <DatePicker fx:id="dateFinVentas" promptText="dd/mm/aaaa" maxWidth="Infinity"
                                style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;">
                    </DatePicker>

                    <Button fx:id="btnConsultarVentas" mnemonicParsing="false"
                            text="Consultar" maxWidth="Infinity"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                              -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 11 0;">
                        <font><Font name="Segoe UI Semibold" size="14.0" /></font>
                        <VBox.margin><Insets top="4.0" /></VBox.margin>
                    </Button>
                </children>
            </VBox>

            <VBox spacing="14.0" styleClass="tarjeta-dashboard"
                  stylesheets="@../stylesCSS/Style-Dashboard.css"
                  GridPane.columnIndex="1" GridPane.rowIndex="0">
                <children>
                    <Label text="Consulta de Productos" textFill="#1e293b">
                        <font><Font name="Segoe UI Semibold" size="18.0" /></font>
                        <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                    </Label>

                    <Label text="Categoría" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <ComboBox fx:id="cbCategoriaProducto" maxWidth="Infinity"
                              promptText="Todas las categorías"
                              style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                                -fx-border-radius: 8; -fx-background-radius: 8;">
                    </ComboBox>

                    <Label text="Stock mínimo" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <Spinner fx:id="spinnerStockMinimo" maxWidth="Infinity" min="0" max="9999" initialValue="0"
                             style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                               -fx-border-radius: 8; -fx-background-radius: 8;">
                    </Spinner>

                    <Button fx:id="btnConsultarProductos" mnemonicParsing="false"
                            text="Consultar" maxWidth="Infinity"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                              -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 11 0;">
                        <font><Font name="Segoe UI Semibold" size="14.0" /></font>
                        <VBox.margin><Insets top="4.0" /></VBox.margin>
                    </Button>
                </children>
            </VBox>

            <VBox spacing="14.0" styleClass="tarjeta-dashboard"
                  stylesheets="@../stylesCSS/Style-Dashboard.css"
                  GridPane.columnIndex="0" GridPane.rowIndex="1">
                <children>
                    <Label text="Consulta de Empleados" textFill="#1e293b">
                        <font><Font name="Segoe UI Semibold" size="18.0" /></font>
                        <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                    </Label>

                    <Label text="Departamento" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <ComboBox fx:id="cbDepartamento" maxWidth="Infinity"
                              promptText="Todos los departamentos"
                              style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                                -fx-border-radius: 8; -fx-background-radius: 8;">
                    </ComboBox>

                    <Label text="Estado" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <ComboBox fx:id="cbEstadoEmpleado" maxWidth="Infinity"
                              promptText="Todos"
                              style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                                -fx-border-radius: 8; -fx-background-radius: 8;">
                    </ComboBox>

                    <Button fx:id="btnConsultarEmpleados" mnemonicParsing="false"
                            text="Consultar" maxWidth="Infinity"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                              -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 11 0;">
                        <font><Font name="Segoe UI Semibold" size="14.0" /></font>
                        <VBox.margin><Insets top="4.0" /></VBox.margin>
                    </Button>
                </children>
            </VBox>

            <VBox spacing="14.0" styleClass="tarjeta-dashboard"
                  stylesheets="@../stylesCSS/Style-Dashboard.css"
                  GridPane.columnIndex="1" GridPane.rowIndex="1">
                <children>
                    <Label text="Consulta General" textFill="#1e293b">
                        <font><Font name="Segoe UI Semibold" size="18.0" /></font>
                        <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                    </Label>

                    <Label text="Tipo de consulta" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <ComboBox fx:id="cbTipoConsulta" maxWidth="Infinity"
                              promptText="Ventas por cliente"
                              style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                                -fx-border-radius: 8; -fx-background-radius: 8;">
                    </ComboBox>

                    <Label text="Parámetro" textFill="#64748b">
                        <font><Font name="Segoe UI" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="txtParametroConsulta" promptText="Ingrese parámetro de búsqueda"
                               style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 12;">
                        <font><Font name="Segoe UI" size="14.0" /></font>
                    </TextField>

                    <Button fx:id="btnConsultarGeneral" mnemonicParsing="false"
                            text="Consultar" maxWidth="Infinity"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                              -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 11 0;">
                        <font><Font name="Segoe UI Semibold" size="14.0" /></font>
                        <VBox.margin><Insets top="4.0" /></VBox.margin>
                    </Button>
                </children>
            </VBox>

        </GridPane>
    </children>
</VBox>
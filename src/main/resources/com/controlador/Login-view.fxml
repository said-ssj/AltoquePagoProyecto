<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" stylesheets="@../stylesCSS/Style-Login.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controlador.ControladorLogin">

    <VBox alignment="CENTER" prefWidth="400.0" spacing="15.0" styleClass="panel-izquierdo">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>
        <children>
            <FontIcon iconColor="#ffffff" iconLiteral="fas-shopping-basket" iconSize="80" />
            <Label styleClass="logo-texto" text="ALToque Pago" />
            <Label styleClass="logo-subtexto" text="Sistema de Autoservicio y Gestión" />
        </children>
    </VBox>

    <VBox alignment="CENTER" spacing="30.0" styleClass="panel-derecho" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="60.0" left="80.0" right="80.0" top="60.0" />
        </padding>
        <children>

            <VBox spacing="5.0" alignment="CENTER_LEFT" maxWidth="400.0">
                <Label styleClass="titulo-login" text="Iniciar Sesión" />
                <Label styleClass="subtitulo-login" text="Ingresa tus credenciales para continuar" />
            </VBox>

            <VBox spacing="20.0" maxWidth="400.0">
                <VBox spacing="8.0">
                    <Label styleClass="etiqueta-form" text="Email o Usuario" />
                    <TextField fx:id="txtUsuario" promptText="ejemplo@correo.com" styleClass="text-field-login" />
                </VBox>

                <VBox spacing="8.0">
                    <Label styleClass="etiqueta-form" text="Contraseña" />
                    <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="text-field-login" />
                </VBox>
            </VBox>

            <Region prefHeight="10.0" />

            <VBox spacing="15.0" maxWidth="400.0">
                <Button fx:id="btnEntrarGestion" maxWidth="Infinity" mnemonicParsing="false" onAction="#ingresarGestion" styleClass="btn-login-principal" text="Entrar a Gestión" />

                <HBox alignment="CENTER">
                    <Region styleClass="linea-separadora" HBox.hgrow="ALWAYS" />
                    <Label text=" o " styleClass="texto-separador" />
                    <Region styleClass="linea-separadora" HBox.hgrow="ALWAYS" />
                </HBox>

                <Button fx:id="btnKiosko" maxWidth="Infinity" mnemonicParsing="false" onAction="#iniciarKiosko" styleClass="btn-login-secundario" text="Iniciar Kiosko de Autoservicio" />
            </VBox>

        </children>
    </VBox>

</HBox>